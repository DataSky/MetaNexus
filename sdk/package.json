{
  "name": "@metanexus/sdk",
  "version": "0.1.0",
  "description": "MetaNexus SDK — Universal agent discovery, trust, and compute-native settlement",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./core": "./dist/core/index.js",
    "./discovery": "./dist/discovery/index.js",
    "./trust": "./dist/trust/index.js",
    "./settlement": "./dist/settlement/index.js",
    "./adapters": "./dist/adapters/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataSky/MetaNexus.git"
  },
  "keywords": [
    "agent",
    "discovery",
    "trust",
    "settlement",
    "a2a",
    "mcp",
    "model-quota-swap"
