# MetaNexus environment variables
# Copy this file to .env and fill in your values

# DMXAPI — semantic search embeddings (OpenAI-compatible)
# Get your key at https://www.dmxapi.cn
DMXAPI_KEY=your-dmxapi-key-here
DMXAPI_BASE_URL=https://www.dmxapi.cn
EMBEDDING_MODEL=qwen3-embedding-8b

# PostgreSQL — production registry storage (optional, uses in-memory by default)
# DATABASE_URL=postgresql://user:password@localhost:5432/metanexus

# Server
# PORT=3000
